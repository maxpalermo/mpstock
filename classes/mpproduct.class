public class MpProduct extends ObjectModelCore
{
    public function addCategory($id_category, $id_product)
    {
        if ($id_category == 0) {
            return;
        }
        try {
            $product = new ProductCore($id_product);
            $product->addToCategories($id_category);
        } catch (Exception $ex) {
            $this->errors[] = $ex->getMessage();
        }
    }
    
    public function addFeature($id_feature, $id_feature_value, $id_product)
    {
        if ($id_feature == 0 || $id_feature_value == 0) {
            return;
        }
        try {
            $product = new ProductCore($id_product);
            $product->addFeaturesToDB($id_feature, $id_feature_value);
        } catch (Exception $ex) {
            $this->errors[] = $ex->getMessage();
        }
    }
    
    public function setOnSale($on_sale, $id_product)
    {
        if ($on_sale) {
            $product = new ProductCore($id_product);
            $product->on_sale = 1;
            $result = $product->update();
            if (!$result) {
                $this->errors[] = Db::getInstance()->getMsgError();
            }
        }
    }
}